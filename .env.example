# OpenAI credentials (optional but recommended for higher-quality summaries)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Optional web ingestion settings
WEB_FETCH_TIMEOUT_SECONDS=20
WEB_FETCH_USER_AGENT=feed-summarizer/1.0 (+https://github.com/danchizik18/feed-summarizer)

# Optional email delivery (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=true
SMTP_TIMEOUT_SECONDS=30
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com
